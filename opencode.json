{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "igmarkets": {
      "type": "local",
      "command": ["npx", "tsx", "src/server.ts"],
      "enabled": true,
      "environment": {
        "IG_API_KEY": "{env:IG_API_KEY}",
        "IG_USERNAME": "{env:IG_USERNAME}",
        "IG_PASSWORD": "{env:IG_PASSWORD}",
        "IG_DEMO": "{env:IG_DEMO}"
      }
    }
  }
}
