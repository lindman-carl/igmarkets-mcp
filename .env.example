# IG Markets MCP Server - Environment Variables
#
# Copy this file to .env and fill in your credentials.
# The server auto-logs in at startup when these are set.

# Your IG Markets API key (get one at https://labs.ig.com/)
IG_API_KEY=

# Your IG Markets account username
IG_USERNAME=

# Your IG Markets account password
IG_PASSWORD=

# Use demo environment (default: true). Set to "false" for live trading.
# WARNING: Live trading uses real money!
IG_DEMO=true
