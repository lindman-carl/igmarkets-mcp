{
  "name": "igmarkets",
  "version": "1.0.0",
  "description": "OpenClaw plugin for IG Markets REST Trading API - 53 tools for trading, market data, and account management",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lindman-carl/igmarkets-mcp"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "ig-markets",
    "trading",
    "cfd",
    "spread-bet"
  ],
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "skills/",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
